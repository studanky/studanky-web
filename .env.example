# -----------------------------------------------------------------------------
# Environment variables for studanky-web.
#
# Copy this file to `.env.local` and fill in the values for local development:
#
#     cp .env.example .env.local
#
# `.env.local` is git-ignored — never commit real values. Production values are
# configured in Coolify, not here. Next.js loads these automatically.
# -----------------------------------------------------------------------------

# Base URL of the public Strapi API, including the `/api` suffix and no trailing
# slash. Used server-side for the spring "preview" payload and the public
# newsletter signup endpoint. See docs/strapi-share-endpoint.md and
# docs/newsletter.md.
#
# REQUIRED for newsletter signup. Also required for the /s/{id} preview to show
# real spring data — without it the preview degrades to a generic install page.
STRAPI_API_BASE=https://api.studankyapp.cz/api
